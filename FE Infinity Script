local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LP = Players.LocalPlayer
local Char = LP.Character or LP.CharacterAdded:Wait()
local Root = Char:WaitForChild("HumanoidRootPart", 10)
local Humanoid = Char:WaitForChild("Humanoid", 10)

local RADIUS = 50
local PUSH_FORCE = 75
local SLOW_POWER = 3
local MAX_NPCS = 200

local ENABLED = true
local ANTI_TOUCH = true
local VISUAL_RING = true

local trackedNPCs = {}
local bodyVelocities = {}
local touchedConns = {}
local rescanTimer = 0
local RESCAN_INTERVAL = 0.5

local visualRing = nil
local ringLastUpdate = 0

local function isNPC(model)
    if not model or model == Char then return false end
    if model.Parent == Char then return false end
    local hum = model:FindFirstChildWhichIsA("Humanoid")
    if not hum or hum == Humanoid or hum.Health <= 0 then return false end
    if Players:GetPlayerFromCharacter(model) then return false end
    return true
end

local function protectChar(char)
    for _, conn in ipairs(touchedConns) do
        pcall(function() conn:Disconnect() end)
    end
    touchedConns = {}

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = false
        end
    end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local c = hum:GetPropertyChangedSignal("Health"):Connect(function()
            if hum.Health > 0 and hum.Health < hum.MaxHealth then
                hum.Health = hum.MaxHealth
            end
        end)
        table.insert(touchedConns, c)
    end
end

protectChar(Char)

LP.CharacterAdded:Connect(function(newChar)
    for _, conn in ipairs(touchedConns) do
        pcall(function() conn:Disconnect() end)
    end
    touchedConns = {}
    for model, bv in pairs(bodyVelocities) do
        if bv and bv.Parent then
            pcall(function() bv:Destroy() end)
        end
    end
    bodyVelocities = {}
    trackedNPCs = {}

    Char = newChar
    Root = Char:WaitForChild("HumanoidRootPart", 10)
    Humanoid = Char:WaitForChild("Humanoid", 10)
    protectChar(Char)
    if ENABLED and VISUAL_RING then
        createVisualRing()
    end
end)

local function scanNPCs()
    local npcs = {}
    local rootPos = Root and Root.Position
    if not rootPos then return npcs end

    local success, parts = pcall(function()
        local overlapParams = OverlapParams.new()
        overlapParams.FilterType = Enum.RaycastFilterType.Exclude
        overlapParams.FilterDescendantsInstances = {Char}
        return workspace:GetPartBoundsInRadius(rootPos, RADIUS, overlapParams)
    end)

    if success and parts then
        local seen = {}
        for _, part in ipairs(parts) do
            local model = part.Parent
            if model and model:IsA("Model") and not seen[model] then
                seen[model] = true
                if isNPC(model) then
                    local hum = model:FindFirstChildWhichIsA("Humanoid")
                    local hrp = model:FindFirstChild("HumanoidRootPart")
                    if hum and hrp and hum.Health > 0 then
                        local dist = (hrp.Position - rootPos).Magnitude
                        table.insert(npcs, {model = model, humanoid = hum, hrp = hrp, distance = dist})
                    end
                end
            end
        end
    else
        for _, model in ipairs(workspace:GetDescendants()) do
            if #npcs >= MAX_NPCS then break end
            if model:IsA("Model") and isNPC(model) then
                local hum = model:FindFirstChildWhichIsA("Humanoid")
                local hrp = model:FindFirstChild("HumanoidRootPart")
                if hum and hrp and hum.Health > 0 then
                    local dist = (hrp.Position - rootPos).Magnitude
                    if dist <= RADIUS then
                        table.insert(npcs, {model = model, humanoid = hum, hrp = hrp, distance = dist})
                    end
                end
            end
        end
    end

    table.sort(npcs, function(a, b) return a.distance < b.distance end)
    if #npcs > MAX_NPCS then
        local t = {}
        for i = 1, MAX_NPCS do t[i] = npcs[i] end
        return t
    end
    return npcs
end

local function createBV(npcData)
    local model = npcData.model
    if bodyVelocities[model] then
        pcall(function() bodyVelocities[model]:Destroy() end)
    end
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.zero
    bv.P = 100000
    bv.Parent = npcData.hrp
    bodyVelocities[model] = bv
    trackedNPCs[model] = {
        humanoid = npcData.humanoid,
        hrp = npcData.hrp,
        originalWalkSpeed = npcData.humanoid.WalkSpeed
    }
end

local function applyForce(npcData)
    local rootPos = Root and Root.Position
    if not rootPos then return end

    local model = npcData.model
    local hum = npcData.humanoid
    local hrp = npcData.hrp
    local dist = npcData.distance
    if dist < 0.01 then dist = 0.01 end

    if not bodyVelocities[model] then
        createBV(npcData)
    end
    local bv = bodyVelocities[model]
    if not bv or not bv.Parent then return end

    local dir = (hrp.Position - rootPos).Unit
    local mult = (RADIUS / dist) ^ 3
    local strength = math.clamp(PUSH_FORCE * mult, PUSH_FORCE, 10000)
    bv.Velocity = dir * strength

    local origSpeed = trackedNPCs[model] and trackedNPCs[model].originalWalkSpeed or 16
    local factor = math.clamp((dist / RADIUS) ^ SLOW_POWER, 0.001, 1)
    local targetSpeed = origSpeed * factor
    hum.WalkSpeed = hum.WalkSpeed + (targetSpeed - hum.WalkSpeed) * 0.3
    if hum.WalkSpeed < 0.05 then hum.WalkSpeed = 0.05 end

    if dist < RADIUS * 0.3 then
        hum.JumpPower = math.clamp(hum.JumpPower * 0.8, 0, 1)
        hum.AutoRotate = false
    end
end

local function cleanupFar(active)
    for model, bv in pairs(bodyVelocities) do
        if not active[model] and bv and bv.Parent then
            local data = trackedNPCs[model]
            if data and data.humanoid and data.humanoid.Parent then
                local orig = data.originalWalkSpeed
                data.humanoid.WalkSpeed = data.humanoid.WalkSpeed + (orig - data.humanoid.WalkSpeed) * 0.1
                if math.abs(data.humanoid.WalkSpeed - orig) < 0.5 then
                    data.humanoid.WalkSpeed = orig
                    data.humanoid.JumpPower = 50
                    data.humanoid.AutoRotate = true
                end
            end
            pcall(function() bv:Destroy() end)
            bodyVelocities[model] = nil
            trackedNPCs[model] = nil
        end
    end
end

local function createVisualRing()
    if visualRing then
        pcall(function() visualRing:Destroy() end)
    end
    if not VISUAL_RING then return end
    visualRing = Instance.new("Part")
    visualRing.Name = "InfinityRing"
    visualRing.Shape = Enum.PartType.Cylinder
    visualRing.Size = Vector3.new(RADIUS * 2, 0.2, RADIUS * 2)
    visualRing.Anchored = true
    visualRing.CanCollide = false
    visualRing.CanTouch = false
    visualRing.CanQuery = false
    visualRing.Transparency = 0.7
    visualRing.Color = Color3.fromRGB(138, 43, 226)
    visualRing.Material = Enum.Material.Neon
    visualRing.Parent = workspace
end

local function updateVisualRing()
    if not VISUAL_RING or not visualRing or not Root then return end
    local now = tick()
    if now - ringLastUpdate < 0.3 then return end
    ringLastUpdate = now
    visualRing.Position = Root.Position
end

local function cleanup()
    ENABLED = false
    for model, bv in pairs(bodyVelocities) do
        local data = trackedNPCs[model]
        if data and data.humanoid and data.humanoid.Parent then
            pcall(function()
                data.humanoid.WalkSpeed = data.originalWalkSpeed
                data.humanoid.JumpPower = 50
                data.humanoid.AutoRotate = true
            end)
        end
        if bv and bv.Parent then
            pcall(function() bv:Destroy() end)
        end
    end
    bodyVelocities = {}
    trackedNPCs = {}
    if visualRing then
        pcall(function() visualRing:Destroy() end)
        visualRing = nil
    end
end

local function toggle()
    ENABLED = not ENABLED
    if ENABLED then
        if VISUAL_RING then createVisualRing() end
        print("[∞] ON")
    else
        cleanup()
        print("[∞] OFF")
    end
end

local function setRadius(r)
    RADIUS = math.clamp(r, 10, 200)
    if VISUAL_RING then createVisualRing() end
    print("[∞] Radius:", RADIUS)
end

local function setForce(f)
    PUSH_FORCE = math.clamp(f, 10, 500)
    print("[∞] Force:", PUSH_FORCE)
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then toggle() end
    if input.KeyCode == Enum.KeyCode.End then cleanup() print("[∞] CLEANED") end
end)

local cachedNPCs = {}
local lastScan = 0

local function tick()
    if not ENABLED then return end
    if not Root or not Root.Parent then
        Char = LP.Character
        if Char then
            Root = Char:FindFirstChild("HumanoidRootPart")
            Humanoid = Char:FindFirstChildOfClass("Humanoid")
        end
        if not Root then return end
    end

    updateVisualRing()

    local now = tick()
    if now - lastScan >= RESCAN_INTERVAL then
        cachedNPCs = scanNPCs()
        lastScan = now
    else
        local rootPos = Root.Position
        for _, npc in ipairs(cachedNPCs) do
            if npc.hrp and npc.hrp.Parent then
                npc.distance = (npc.hrp.Position - rootPos).Magnitude
            end
        end
    end

    local active = {}
    for _, npc in ipairs(cachedNPCs) do
        if npc.distance <= RADIUS and npc.hrp and npc.hrp.Parent and npc.humanoid and npc.humanoid.Health > 0 then
            active[npc.model] = true
            applyForce(npc)
        end
    end
    cleanupFar(active)
end

if VISUAL_RING then createVisualRing() end

local running = true
task.spawn(function()
    while running do
        pcall(tick)
        task.wait(0.08)
    end
end)

getgenv().InfinityAura = {
    Toggle = toggle,
    Enable = function() ENABLED = true if VISUAL_RING then createVisualRing() end end,
    Disable = cleanup,
    SetRadius = setRadius,
    SetForce = setForce,
    IsEnabled = function() return ENABLED end,
    Cleanup = cleanup,
}

print("[∞] INFINITY AURA LOADED | RightShift=Toggle | End=Cleanup")
return getgenv().InfinityAura
